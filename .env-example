# ============================================================
# .env-example — copy this file to .env and fill in your keys
# NEVER commit .env to version control
# ============================================================

# ---- LLM Provider ----
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ---- Optional overrides ----
# Override model name (default set in config/setup.json)
# LLM_MODEL=claude-sonnet-4-6

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
