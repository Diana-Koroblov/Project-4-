# ============================================================
# .env-example — copy this file to .env and fill in your keys
# NEVER commit .env to version control
# ============================================================

# ---- LLM Provider (set the key for whichever provider you use) ----
# Groq (team default — set provider=groq in config/setup.json)
GROQ_API_KEY=your-groq-api-key-here

# Google Gemini (alternative — set provider=gemini in config/setup.json)
# GEMINI_API_KEY=your-gemini-api-key-here

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
