# ============================================================
# .env-example — copy this file to .env and fill in your keys
# NEVER commit .env to version control
# ============================================================

# ---- LLM Provider ----
GROQ_API_KEY=your-groq-api-key-here

# ---- Optional overrides ----
# Override model name (default set in config/setup.json)
# LLM_MODEL=llama-3.3-70b-versatile

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
