# ============================================================
# .env-example — copy this file to .env and fill in your keys
# NEVER commit .env to version control
# ============================================================

# ---- LLM Provider ----
# Groq (provider=groq in config/setup.json — the only supported provider)
GROQ_API_KEY=your-groq-api-key-here

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
