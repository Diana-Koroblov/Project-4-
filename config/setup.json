{
  "llm": {
    "provider": "groq",
    "model": "llama-3.3-70b-versatile",
    "temperature": 0.0,
    "max_tokens": 4096
  },
  "agent": {
    "max_iterations": 10,
    "verbose": false,
    "token_budget": 100000
  },
  "paths": {
    "obsidian_vault": "obsidian/",
    "source_root": "src/broken-python/",
    "reports_dir": "reports/",
    "results_dir": "results/"
  },
  "extensions": {
    "orphan_detector": {
      "enabled": true,
      "max_edge_threshold": 1
    }
  }
}
