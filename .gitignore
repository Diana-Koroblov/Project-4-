# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Secrets — never commit real credentials
.env
*.key
*.pem
credentials.json

# Runtime logs (rotating debug logs are regenerated on every run)
*.log
*.log.*

# Test/lint tooling artifacts (regenerated on every run)
.coverage
.coverage.*
.pytest_cache/
.ruff_cache/
